{
    "types": {
        "StrobeMode": {
            "type": "enum",
            "values": [
                "DISABLED",
                "INTERNAL_SINGLE",
                "INTERNAL_RAPID",
                "EXTERNAL_POS",
                "EXTERNAL_NEG"
            ]
        },
        "Segment": {
            "type": "enum",
            "values": [
                "TAIL",
                "BRAKE",
                "SIGNAL_LEFT",
                "SIGNAL_RIGHT"
            ]
        },
        "AdcChannel": {
            "type": "enum",
            "values": [
                "McuTemperature",
                "DriveTemperature",
                "Reserved1",
                "Reserved2",
                "BatteryVoltage",
                "TailDriverVoltage",
                "Reserved3",
                "Reserved4"
            ]
        },
        "DriverFault": {
            "type": "enum",
            "values": [
                "NoError",
                "OverTemperature",
                "OpenLoad",
                "ShortToGround",
                "ShortToVcc"
            ]
        },
        "DriverStatus": {
            "type": "struct",
            "fields": {
                "TailLightStatus": {
                    "type": "DriverFault"
                },
                "BrakeLightStatus": {
                    "type": "DriverFault"
                },
                "SignalLeftStatus": {
                    "type": "DriverFault"
                },
                "SignalRightStatus": {
                    "type": "DriverFault"
                }
            }
        },
        "ImuData": {
            "type": "struct",
            "fields": {
                "AccelX": {
                    "type": "int16_t"
                },
                "AccelY": {
                    "type": "int16_t"
                },
                "AccelZ": {
                    "type": "int16_t"
                },
                "GyroX": {
                    "type": "int16_t"
                },
                "GyroY": {
                    "type": "int16_t"
                },
                "GyroZ": {
                    "type": "int16_t"
                }
            }
        }
    },
    "services": {
        "Config_Reload": {
            "id": "0x3000",
            "description": "Updates the configuration with the latest UDS property values",
            "group": "Configuration",
            "params": {},
            "return": "void"
        },
        "Config_Save": {
            "id": "0x3001",
            "description": "Saves the current UDS property values to EEPROM",
            "group": "Configuration",
            "params": {},
            "return": "void"
        },
        "Calib_Brightness": {
            "id": "0x3002",
            "description": "Changes an entry in the brightness curve calibration table",
            "group": "Calibration",
            "params": {
                "Duty": {
                    "type": "uint8_t"
                },
                "Value": {
                    "type": "uint8_t"
                }
            },
            "return": "bool"
        },
        "Calib_Voltage": {
            "id": "0x3003",
            "description": "Changes the voltage calibration values for battery voltage readings",
            "group": "Calibration",
            "params": {
                "Slope": {
                    "type": "uint16_t"
                },
                "Offset": {
                    "type": "int16_t"
                }
            },
            "return": "void"
        },
        "Calib_Save": {
            "id": "0x3004",
            "description": "Saves the current calibration values to EEPROM",
            "group": "Calibration",
            "params": {},
            "return": "void"
        },
        "Driver_Control": {
            "id": "0x3010",
            "description": "Tests each segment of the light",
            "group": "Driver",
            "params": {
                "Segment": {
                    "type": "Segment"
                },
                "Brightness": {
                    "type": "uint16_t"
                }
            },
            "return": "void"
        },
        "Driver_Status": {
            "id": "0x3011",
            "description": "Returns the current status of the LED driver",
            "group": "Driver",
            "params": {},
            "return": "DriverStatus"
        },
        "Adc_Read": {
            "id": "0x3020",
            "description": "Reads the value of an ADC channel",
            "group": "IO",
            "params": {
                "Channel": {
                    "type": "AdcChannel"
                }
            },
            "return": "uint16_t"
        },
        "Imu_Read": {
            "id": "0x3030",
            "description": "Reads the current IMU data",
            "group": "IO",
            "params": {},
            "return": "ImuData"
        },
        "Imu_Calibrate": {
            "id": "0x3031",
            "description": "Calibrates the IMU by taking multiple readings and calculating offsets",
            "group": "IO",
            "params": {},
            "return": "void"
        }
    },
